# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown：保留行尾兩個空白（換行語意）
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML（mkdocs.yml、GitHub Actions、範本）
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Makefile（如有）
[Makefile]
indent_style = tab
